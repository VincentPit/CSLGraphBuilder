# ──────────────────────────────────────────────────────────────────────────────
# GraphBuilder — environment variable reference
# Copy this file to .env and fill in the values.
# .env is gitignored; NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Connection URI (bolt:// for direct, neo4j+s:// for AuraDB)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Storage backend ("neo4j" | "in_memory")
DATABASE_PROVIDER=neo4j

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported: openai | azure_openai | anthropic | huggingface | local
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini

# OpenAI
LLM_API_KEY=sk-...

# Azure OpenAI (required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# ── Web Crawler ────────────────────────────────────────────────────────────────
# Comma-separated allowed domains (empty = unrestricted)
CRAWLER_ALLOWED_DOMAINS=
CRAWLER_BLOCKED_DOMAINS=
CRAWLER_MAX_URLS=200
CRAWLER_MAX_WORKERS=10
# Seconds between requests
CRAWLER_REQUEST_DELAY=1.0
CRAWLER_TIMEOUT=30
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_USER_AGENT=GraphBuilder/2.0 (+https://github.com/VincentPit/GraphBuilder)

# ── Document Processing ────────────────────────────────────────────────────────
PROCESSING_CHUNK_SIZE=512
PROCESSING_CHUNK_OVERLAP=50
PROCESSING_MAX_CHUNKS=1000
# sequential | parallel | batch | stream
PROCESSING_MODE=parallel
PROCESSING_MAX_CONCURRENT_TASKS=5

# ── Logging ────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json
# Leave empty to log to stdout only
LOG_FILE=

# ── Application ────────────────────────────────────────────────────────────────
# development | staging | production | testing
ENVIRONMENT=development

# ── Security ───────────────────────────────────────────────────────────────────
ENABLE_API_RATE_LIMITING=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=3600
